# ═══════════════════════════════════════════════════════════
# .gitignore — Cell Cycle Intelligence System
# ═══════════════════════════════════════════════════════════

# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/

# ── Virtual environments ─────────────────────────────────
venv/
env/
.venv/
.env/

# ── Data files (large, downloadable separately) ──────────
data/BBBC048v1.zip
data/BBBC048_raw/
data/synthetic/
!data/README.md
!data/Ground_truth.lst

# ── Output (generated by pipeline) ───────────────────────
output/
!output/.gitkeep

# ── Model weights ────────────────────────────────────────
*.pth
*.pt
*.onnx
*.h5

# ── Keep frontend tracked ─────────────────────────────────
!frontend/

# ── IDE / Editor ─────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS files ─────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Jupyter Notebooks checkpoints ────────────────────────
.ipynb_checkpoints/

# ── Logs ─────────────────────────────────────────────────
*.log

# ── LaTeX build artifacts ────────────────────────────────
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.lof
*.lot
*.out
*.run.xml
*.synctex.gz
*.toc
